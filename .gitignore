# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv
env/
venv/

# Unit test / coverage reports
.pytest_cache/
.coverage
htmlcov/

# Ruff
.ruff_cache/

# Experiment outputs (reproducible from run.py)
!experiments/*/.gitkeep
!experiments/*/results/.gitkeep
!experiments/*/figures/.gitkeep
!experiments/*/logs/.gitkeep

# Bulky / regenerable per-experiment artifacts (checkpoints, latent caches,
# token caches, intermediate text outputs). Each experiment writes these to
# its own out/ dir; they're regenerable from run.py.
experiments/*/out/

# Data (activation caches, checkpoints — too large for git)
data/**/*.pt
data/**/
!data/.gitkeep

# Legacy directories (migrated)
/checkpoints/
/results/

# Model files
*.pt

# Environment variables
.env
.envrc
